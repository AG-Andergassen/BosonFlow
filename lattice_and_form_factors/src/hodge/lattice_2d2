lattice_2D_t::lattice_2D_t(std::tuple<coord_t, coord_t> real_basis, double BZ_points_per_unit_length)
{
    m_real_basis[0] = std::get<0>(real_basis);
    m_real_basis[1] = std::get<1>(real_basis);
    m_span = span_lattice(m_real_basis);
    m_norms_squared = compute_norms_squared(m_span);
    m_shells = make_shells(m_span, m_norms_squared);
    m_reciprocal_basis = get_reciprocal_lattice_basis(m_real_basis);
    //std::cout<<"b: "<< std::get<1>(std::get<1>(m_reciprocal_basis)) << std::endl;
    std::tie(m_BZ_mesh, m_BZ_mesh_min_interpoint_spacing) = span_patched_BZ_wigner_seitz(m_reciprocal_basis, BZ_points_per_unit_length);
}

// base
std::vector<coord_t> lattice_2D_t::span_lattice(std::array<coord_t, 2> basis, unsigned range )
{
    std::vector<coord_t> span;
    double rx, ry;
    for (int b = -range; b < static_cast<int>(range)+1; b++)
    for (int a = -range; a < static_cast<int>(range)+1; a++){
	coord_t basis_vec1 = basis[0];
	coord_t basis_vec2 = basis[1];
	coord_t r = basis_vec1*a + basis_vec2*b;
	span.push_back(r);
    }
    return span;
}

std::vector<double> lattice_2D_t::compute_norms_squared(const std::vector<coord_t> &vecs)
{
    std::vector<double> norms_squared;
    for (const coord_t &vec : vecs){
	double norm_squared = vec.dot(vec);
	norms_squared.push_back(norm_squared);
    } 
    return norms_squared;
}

std::map<double, std::vector<coord_t> > lattice_2D_t::make_shells(const std::vector<coord_t> &span, const std::vector<double> &norms_squared)
{
    std::map<double, std::vector<coord_t>> shells;
    if (span.size() == 0)
	throw std::invalid_argument("The set of points \"span\" given to make shells of is empty.");
    
    for (unsigned i =0; i < norms_squared.size(); i ++){
	bool key_exists = false;
	for (auto itr = shells.begin(); itr != shells.end(); itr ++){
	    double norm_squared = itr->first;
	    // if a shell with this distance is already there, add lattice vector to shell. 
	    if (std::abs(norms_squared[i] - norm_squared) < epsilon){
		key_exists = true;
		shells[norm_squared].push_back(span[i]);
	    }
	}
	// if no shell with that distance exists, create a new shell with this lattice vector in it
	if (! key_exists){
	    shells[norms_squared[i]] = {span[i]};
	}
    }
    return shells;
}

std::map<double, std::vector<coord_t> > lattice_2D_t::make_shells(const std::vector<coord_t> &span)
{
    std::vector<double> norms_squared;
    norms_squared = compute_norms_squared(span);
    return make_shells(span, norms_squared);
}

double lattice_2D_t::get_parallelogram_area(std::array<coord_t, 2> vecs)
{
    coord_t vec1 = vecs[0];
    coord_t vec2 = vecs[1];
    return std::abs(vec1(0) * vec2(1) - vec1(1)*vec2(0));
}

coord_t lattice_2D_t::get_orthogonal_vec_2D(coord_t vec)
{
    return {vec(1), - vec(0)};
}

std::array<coord_t, 2> lattice_2D_t::get_reciprocal_lattice_basis(std::array<coord_t, 2> real_basis)
{
    double prefactor = 2 * M_PI /get_parallelogram_area(real_basis);
    coord_t basis1 = get_orthogonal_vec_2D(real_basis[1]) * prefactor;
    coord_t basis2 = get_orthogonal_vec_2D(real_basis[0]) * (-prefactor);
    return {basis1, basis2};
}

std::unordered_map<coord_t, unsigned, CoordHash<coord_t> > lattice_2D_t::get_coord_to_idx_map(const std::vector<coord_t> &BZ_mesh)
{
    std::unordered_map<coord_t, unsigned, CoordHash<coord_t> > coord_to_idx;
    for (unsigned k_idx = 0; k_idx < BZ_mesh.size(); k_idx++){
	coord_to_idx[BZ_mesh[k_idx]] = k_idx;
    }
    return coord_to_idx;
}

std::tuple<unsigned, double> lattice_2D_t::get_idx_from_coord(coord_t coord, const std::vector<coord_t> &mesh)
{
    unsigned idx;
    double deviation;
    bool is_first = true;
    for (unsigned i = 0; i < mesh.size(); i ++){
	coord_t potential_coord = mesh[i];
	//double norm = sqrt(std::pow(std::get<0>(potential_coord) - std::get<0>(coord), 2) + std::pow(std::get<1>(potential_coord) - std::get<1>(coord), 2));
	double norm = std::sqrt((potential_coord - coord).dot(potential_coord - coord));
	if (is_first || norm < deviation){
	    is_first = false;
	    deviation = norm;
	    idx = i;
	}
    }
    return {idx, deviation};
}

std::tuple<unsigned, double> lattice_2D_t::get_mom_idx_from_coord(coord_t coord)
{
    std::vector<std::tuple<unsigned, double> > idxes_and_deviations;
    bool is_first = true;
    
    unsigned smallest_deviation_idx;
    double smallest_deviation;

    // handle periodicity
    for (int a = -1; a <= 1; a++)
    for (int b = -1; b <= 1; b++){
	coord_t shifted_coord = coord + m_reciprocal_basis[0] * a + m_reciprocal_basis[1] * b;
	auto [idx, deviation] = get_idx_from_coord(shifted_coord, m_BZ_mesh );
	if (is_first){
	    is_first = false;
	    smallest_deviation_idx = idx;
	    smallest_deviation = deviation;
	    continue;
	}
	if (deviation < smallest_deviation){
	    smallest_deviation_idx = idx;
	    smallest_deviation = deviation;
	}
    }

    return std::make_tuple(smallest_deviation_idx, smallest_deviation/m_BZ_mesh_min_interpoint_spacing);
}

